VITE_API_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — only needed for "Continue with Google" (Cognito Hosted UI).
# Copy from `terraform output cognito_hosted_ui_domain`. Leave unset to disable.
# VITE_COGNITO_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173
# VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173
